# ===== ENVIRONMENT VARIABLES - HostItSmart pe set karo =====
# Inhe copy karo aur apni values dalo

SECRET_KEY=your_very_secret_key_here_change_this

# Email Settings (Gmail App Password use karo)
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=xxxx xxxx xxxx xxxx

# Flask Settings (production pe false rakho)
FLASK_DEBUG=false

# Port (hosting platform automatically set karta hai)
# PORT=5000
